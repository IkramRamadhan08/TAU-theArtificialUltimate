#!/usr/bin/env bash

set -euxo pipefail

if [ "$#" -ne 1 ]; then
  echo "Usage: $0 <release_version>"
  exit 1
fi

mkdir -p snap/gui

export DO_STARTUP_NOTIFY="true"
export APP_NAME="Tau"
export APP_CLI="tau"
export APP_ICON="\${SNAP}/meta/gui/tau.png"
export APP_ARGS="%U"
envsubst < "crates/tau/resources/tau.desktop.in" > "snap/gui/tau.desktop"
cp "crates/tau/resources/app-icon.png" "snap/gui/tau.png"

RELEASE_VERSION="$1" envsubst < crates/tau/resources/snap/snapcraft.yaml.in > snap/snapcraft.yaml

# Clean seems to be needed to actually check that the snapcraft.yaml
# works.  For example, when a `stage-package` is removed, it will
# still remain on rebuild.
snapcraft clean

snapcraft
